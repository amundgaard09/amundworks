{
    "version": "2.0.0",
    "tasks": [
        {
            "label": "build and run C program",
            "type": "shell",
            "command": "gcc",
            "args": [
                "test.c",
                "-o", "program"
            ],
            "group": {
                "kind": "build",
                "isDefault": true
            },
            "problemMatcher": ["$gcc"],
            "detail": "Kompilerer og kjører C-programmet"
        },
        {
            "label": "run program",
            "type": "shell",
            "command": "./test",
            "group": {
                "kind": "test",
                "isDefault": true
            },
            "dependsOn": ["build and run C program"],
            "detail": "Kjører det kompilert programmet"
        }
    ]
}
