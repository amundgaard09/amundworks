{
  "version": "2.0.0",
  "options": {
    "shell": {
      "executable": "cmd.exe",
      "args": ["/d", "/c"]
    }
  },
  "tasks": [
    {
      "label": "Kompiler alle C-filer",
      "type": "shell",
      "command": "gcc",
      "args": [
        "*.c",
        "-o",
        "output.exe"
      ],
      "group": "build",
      "problemMatcher": ["$gcc"],
      "detail": "Kompilerer alle .c-filer i mappen"
    },
    {
      "label": "Kjør programmet",
      "type": "shell",
      "command": "output.exe",
      "group": {
        "kind": "test",
        "isDefault": true
      },
      "presentation": {
        "echo": true,
        "reveal": "always",
        "focus": false,
        "panel": "shared"
      }
    }
  ]
}
